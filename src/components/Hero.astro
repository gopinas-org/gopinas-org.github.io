---
import CdnImage from './CdnImage.astro';
import { HERO_IMAGE_SRC, LOGO_MARK_URL } from '../config/media';
import { heroImageOptimizeOpts } from '../lib/heroImage';

interface Props {
  variant: 'home' | 'compact';
}

const { variant } = Astro.props;
---

{
  variant === 'home' ? (
    <header class="hero py-2 py-lg-3 px-3">
      <div class="hero-photo" aria-hidden="true">
        <CdnImage
          src={HERO_IMAGE_SRC}
          alt=""
          width={heroImageOptimizeOpts.width}
          height={heroImageOptimizeOpts.height}
          crop={heroImageOptimizeOpts.crop}
          class="hero-photo-img"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="container text-start">
        <div class="hero-brand d-flex flex-column flex-md-row align-items-start align-items-md-center mb-2 mb-md-3">
          <a
            class="hero-logo-link flex-shrink-0"
            id="site-hero-logo"
            href="/"
            aria-label="GoPinas home"
          >
            <CdnImage
              src={LOGO_MARK_URL}
              alt=""
              width={256}
              height={256}
              crop="fill"
              class="hero-logo img-fluid"
              loading="eager"
            />
          </a>
          <div class="hero-brand-text">
            <h1 class="hero-brand-title mb-0">GoPinas!</h1>
            <p class="hero-brand-legal mb-0">Go Federation of the Philippines</p>
            <p class="hero-brand-tagline mb-0">let's grow stronger together</p>
          </div>
        </div>
      </div>
    </header>
  ) : (
    <header class="hero py-2 py-lg-3 px-3">
      <div class="hero-photo" aria-hidden="true">
        <CdnImage
          src={HERO_IMAGE_SRC}
          alt=""
          width={heroImageOptimizeOpts.width}
          height={heroImageOptimizeOpts.height}
          crop={heroImageOptimizeOpts.crop}
          class="hero-photo-img"
          loading="eager"
        />
      </div>
      <div class="container text-start">
        <div class="hero-brand d-flex flex-column flex-md-row align-items-start align-items-md-center mb-2 mb-md-3">
          <a
            class="hero-logo-link flex-shrink-0"
            id="site-hero-logo"
            href="/"
            aria-label="GoPinas home"
          >
            <CdnImage
              src={LOGO_MARK_URL}
              alt=""
              width={256}
              height={256}
              crop="fill"
              class="hero-logo img-fluid"
              loading="eager"
            />
          </a>
          <div class="hero-brand-text">
            <span class="hero-brand-title mb-0 d-block">GoPinas!</span>
            <span class="hero-brand-legal mb-0 d-block">Go Federation of the Philippines</span>
            <span class="hero-brand-tagline mb-0 d-block">let's grow stronger together</span>
          </div>
        </div>
      </div>
    </header>
  )
}
