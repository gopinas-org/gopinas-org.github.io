---
import SiteNav from './SiteNav.astro';
import SiteFooter from './SiteFooter.astro';
import Seo from './Seo.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  ogImage?: string;
  ogType?: string;
  isHome?: boolean;
  jsonLdAboutGo?: boolean;
}

const { title, description, canonicalPath, ogImage, ogType, isHome, jsonLdAboutGo } = Astro.props;
const pathname = Astro.url.pathname;

const aboutGoLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'What is Go? weiqi, baduk and the game from China',
  description:
    'Go is a strategic board game from China, also known as weiqi (围棋) and baduk (바둑). GoPinas is the national federation for Go in the Philippines.',
  url: 'https://gopinas.org/about-go.html',
  inLanguage: 'en',
  publisher: {
    '@type': 'Organization',
    name: 'Go Federation of the Philippines, Inc.',
    url: 'https://gopinas.org/',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/assets/favicon-32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/assets/favicon-16.png" sizes="16x16" />
    <link rel="icon" type="image/png" href="/assets/favicon-192.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    {
      isHome && (
        <>
          <link rel="preload" as="image" href="/assets/hero-go-kids.png?v=8" />
          <link rel="preload" as="font" href="/assets/Grift-Thin.woff2" type="font/woff2" crossorigin />
        </>
      )
    }
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/assets/site.css" />
    <Seo title={title} description={description} canonicalPath={canonicalPath} ogImage={ogImage} ogType={ogType} />
    {jsonLdAboutGo && <script type="application/ld+json" set:html={JSON.stringify(aboutGoLd)} />}
  </head>
  <body class="d-flex flex-column min-vh-100">
    <SiteNav pathname={pathname} />
    <slot />
    <SiteFooter pathname={pathname} />
  </body>
</html>
