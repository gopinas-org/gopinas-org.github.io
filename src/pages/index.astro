---
import BaseLayout from '../components/BaseLayout.astro';
import CdnImage from '../components/CdnImage.astro';
import Hero from '../components/Hero.astro';
import ArticleShowcase from '../components/ArticleShowcase.astro';
import { getCollection } from 'astro:content';
import { formatDate, toYmdLocal } from '../lib/formatDate';

const allNews = (await getCollection('news')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const newsList = allNews.slice(0, 10);

const allEvents = (await getCollection('events')).sort(
  (a, b) => a.data.event_date.valueOf() - b.data.event_date.valueOf(),
);
const today = toYmdLocal(new Date());
const upcomingEvents = allEvents.filter((e) => toYmdLocal(e.data.event_date) >= today);

const allArticles = await getCollection('articles');
const featured = allArticles
  .filter((a) => a.data.showcase === true)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);
---

<BaseLayout
  title="GoPinas! — News"
  description="Go Federation of the Philippines — news, events, and featured articles."
  canonicalPath="/"
  isHome
>
  <Hero variant="home" />
  <main class="container container-lg py-4 pb-5 flex-grow-1">
    <ArticleShowcase articles={featured} />

    <section id="upcoming-events" class="upcoming-events-section scroll-target mb-5" aria-labelledby="upcoming-events-heading">
      <h2 id="upcoming-events-heading" class="heading-rule fs-3 fw-bold mb-3">Upcoming Events</h2>
      {
        upcomingEvents.length === 0 ? (
          <p>
            Upcoming dates, venues, and registration will be posted here. Check back soon or reach out through{' '}
            <a class="content-link" href="/about/#team">our contacts on About Us</a> for the latest.
          </p>
        ) : (
          <>
            <ul class="list-unstyled mb-0">
              {upcomingEvents.map((e) => (
                <li class="mb-3">
                  {e.data.image ? (
                    <a
                      class="home-entry-link d-flex gap-4 align-items-start text-reset text-decoration-none"
                      href={`/events/${e.id}/`}
                    >
                      <div class="home-entry-thumb-wrap rounded">
                        <CdnImage
                          class="home-entry-thumb"
                          src={e.data.image}
                          alt=""
                          width={420}
                          height={280}
                        />
                      </div>
                      <span class="d-block min-w-0 flex-grow-1">
                        <span class="article-entry-meta">
                          <span class="home-entry-link-title d-inline fw-semibold">{e.data.title}</span>
                          <span class="article-date small">
                            <span class="article-meta-sep" aria-hidden="true">— </span>
                            {formatDate(e.data.event_date)}
                            {e.data.location && ` · ${e.data.location}`}
                          </span>
                        </span>
                      </span>
                    </a>
                  ) : (
                    <>
                      <span class="article-entry-meta">
                        <a class="home-entry-link-title fw-semibold" href={`/events/${e.id}/`}>{e.data.title}</a>
                        <span class="article-date small">
                          <span class="article-meta-sep" aria-hidden="true">— </span>
                          {formatDate(e.data.event_date)}
                          {e.data.location && ` · ${e.data.location}`}
                        </span>
                      </span>
                    </>
                  )}
                </li>
              ))}
            </ul>
            <p class="mt-3 mb-0">
              <a class="content-link" href="/events/">All events</a>
            </p>
          </>
        )
      }
    </section>

    <section id="news" class="news-section scroll-target mb-5" aria-labelledby="news-heading">
      <h2 id="news-heading" class="heading-rule fs-3 fw-bold mb-3">News</h2>
      {
        newsList.length === 0 ? (
          <p>
            Announcements and updates from GoPinas will appear here. Check back soon or reach out through{' '}
            <a class="content-link" href="/about/#team">our contacts on About Us</a>.
          </p>
        ) : (
          <>
            <ul class="list-unstyled mb-0">
              {newsList.map((n) => (
                <li class="mb-3">
                  {n.data.image ? (
                    <a
                      class="home-entry-link d-flex gap-4 align-items-start text-reset text-decoration-none"
                      href={`/news/${n.id}/`}
                    >
                      <div class="home-entry-thumb-wrap rounded">
                        <CdnImage
                          class="home-entry-thumb"
                          src={n.data.image}
                          alt=""
                          width={420}
                          height={280}
                        />
                      </div>
                      <span class="d-block min-w-0 flex-grow-1">
                        <span class="article-entry-meta">
                          <span class="home-entry-link-title d-inline fw-semibold">{n.data.title}</span>
                          <span class="article-date small">
                            <span class="article-meta-sep" aria-hidden="true">— </span>
                            {formatDate(n.data.date)}
                          </span>
                        </span>
                        {n.data.excerpt && <p class="mb-0 mt-2 text-body small">{n.data.excerpt}</p>}
                      </span>
                    </a>
                  ) : (
                    <>
                      <span class="article-entry-meta">
                        <a class="home-entry-link-title fw-semibold" href={`/news/${n.id}/`}>{n.data.title}</a>
                        <span class="article-date small">
                          <span class="article-meta-sep" aria-hidden="true">— </span>
                          {formatDate(n.data.date)}
                        </span>
                      </span>
                      {n.data.excerpt && <p class="mb-0 mt-1 text-body small">{n.data.excerpt}</p>}
                    </>
                  )}
                </li>
              ))}
            </ul>
            <p class="mt-3 mb-0">
              <a class="content-link" href="/news/">All news</a>
            </p>
          </>
        )
      }
    </section>
  </main>
</BaseLayout>
