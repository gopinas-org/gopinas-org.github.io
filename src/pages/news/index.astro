---
import BaseLayout from '../../components/BaseLayout.astro';
import CdnImage from '../../components/CdnImage.astro';
import Hero from '../../components/Hero.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../lib/formatDate';

const sorted = (await getCollection('news')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="News | GoPinas"
  description="News and announcements from Go Federation of the Philippines."
  canonicalPath="/news/"
>
  <Hero variant="compact" />
  <main class="container container-lg py-4 pb-5 flex-grow-1">
    <h1 class="heading-rule fs-3 fw-bold mb-4">News</h1>
    {
      sorted.length === 0 ? (
        <p>No news posts yet.</p>
      ) : (
        <ul class="list-unstyled mb-0">
          {sorted.map((n) => (
            <li class="mb-4">
              {n.data.image ? (
                <a
                  class="home-entry-link d-flex gap-4 align-items-start text-reset text-decoration-none"
                  href={`/news/${n.id}/`}
                >
                  <div class="home-entry-thumb-wrap rounded">
                    <CdnImage
                      class="home-entry-thumb"
                      src={n.data.image}
                      alt=""
                      width={420}
                      height={280}
                    />
                  </div>
                  <span class="d-block min-w-0 flex-grow-1">
                    <span class="d-block">
                      <span class="home-entry-link-title d-inline fw-semibold">{n.data.title}</span>
                      <span class="article-date small"> — {formatDate(n.data.date)}</span>
                    </span>
                    {n.data.excerpt && <p class="mb-0 mt-2 text-body small">{n.data.excerpt}</p>}
                  </span>
                </a>
              ) : (
                <>
                  <a class="home-entry-link-title fw-semibold" href={`/news/${n.id}/`}>
                    {n.data.title}
                  </a>
                  <span class="article-date small"> — {formatDate(n.data.date)}</span>
                  {n.data.excerpt && <p class="mb-0 mt-1">{n.data.excerpt}</p>}
                </>
              )}
            </li>
          ))}
        </ul>
      )
    }
  </main>
</BaseLayout>
