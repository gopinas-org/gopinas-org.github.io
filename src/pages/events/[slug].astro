---
import BaseLayout from '../../components/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { getCollection, render } from 'astro:content';
import { formatDate } from '../../lib/formatDate';

export async function getStaticPaths() {
  const posts = await getCollection('events');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;
const description = d.location ? `${d.title} — ${d.location}` : d.title;
const ogImage = d.image;
const flickr = d.flickr_album;
const flickrTitle = flickr?.embed_title ?? d.title;
---

<BaseLayout
  title={`${post.data.title} | GoPinas`}
  description={description}
  canonicalPath={`/events/${post.id}/`}
  ogImage={ogImage}
>
  <Hero variant="compact" />
  <main class="container container-lg py-4 pb-5 flex-grow-1">
    <article>
      <header class="mb-4">
        <h1 class="heading-rule fs-3 fw-bold mb-2">{post.data.title}</h1>
        <p class="mb-1">
          <strong>Date:</strong>
          <time datetime={d.event_date.toISOString().slice(0, 10)}>{formatDate(d.event_date)}</time>
          {
            d.end_date && (
              <>
                {' '}
                – <time datetime={d.end_date.toISOString().slice(0, 10)}>{formatDate(d.end_date)}</time>
              </>
            )
          }
        </p>
        {d.location && <p class="mb-1"><strong>Location:</strong> {d.location}</p>}
        {
          d.registration_url && (
            <p class="mb-0">
              <a class="content-link" href={d.registration_url} rel="noopener noreferrer">
                Registration / details
              </a>
            </p>
          )
        }
      </header>
      {
        d.image && (
          <figure class="article-thumb-figure mb-4">
            <img
              class="img-fluid rounded article-thumb-img"
              src={d.image}
              alt={d.image_alt ?? d.title}
              width="1200"
              height="630"
              decoding="async"
            />
          </figure>
        )
      }
      <div class="post-content">
        <Content />
      </div>
      {
        flickr && (
          <section class="flickr-embed mt-5 pt-4 border-top" aria-labelledby="flickr-embed-heading">
            <h2 id="flickr-embed-heading" class="fs-5 fw-semibold mb-3">
              Photos
            </h2>
            <div class="flickr-embed-ratio">
              <a data-flickr-embed="true" href={flickr.href} title={flickrTitle}>
                <img
                  src={flickr.preview_src}
                  width={flickr.preview_width ?? 1600}
                  height={flickr.preview_height ?? 1200}
                  alt={flickrTitle}
                  class="img-fluid rounded"
                  loading="lazy"
                  decoding="async"
                />
              </a>
            </div>
            <script is:inline async src="https://embedr.flickr.com/assets/client-code.js" charset="utf-8"></script>
            <p class="small text-secondary mb-0 mt-2">
              <a class="content-link" href={flickr.href} rel="noopener noreferrer">
                Open album on Flickr
              </a>
            </p>
          </section>
        )
      }
    </article>
  </main>
</BaseLayout>
